<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Flashcards.ViewModels"
    xmlns:models="using:Flashcards.Models"
    xmlns:converters="using:Flashcards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="460"
    d:DesignHeight="800"
    x:Class="Flashcards.Views.MainView"
    x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <converters:MultiBooleanAndConverter x:Key="MultiBooleanAndConverter" />
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <SolidColorBrush x:Key="TabSelectedBg" Color="#CC3B82F6" />
        <SolidColorBrush x:Key="TabUnselectedBg" Color="#33475569" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.tab-btn">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFE2E8F0" />
            <Setter Property="Background" Value="{StaticResource TabUnselectedBg}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tab-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#44475569" />
        </Style>
        <Style Selector="Button.tab-btn.selected">
            <Setter Property="Background" Value="{StaticResource TabSelectedBg}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.tab-btn.selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#DD3B82F6" />
        </Style>
        <!-- Icon button base style -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
        <Style Selector="Button.icon-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#55FFFFFF" />
        </Style>
        <Style Selector="Button.icon-btn:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.35" />
        </Style>
        <!-- MBSP choice result styles -->
        <Style Selector="Button.choice-correct /template/ ContentPresenter">
            <Setter Property="Background" Value="#4422C55F" />
        </Style>
        <Style Selector="Button.choice-correct">
            <Setter Property="BorderBrush" Value="#AA22C55F" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.choice-wrong /template/ ContentPresenter">
            <Setter Property="Background" Value="#44EF4444" />
        </Style>
        <Style Selector="Button.choice-wrong">
            <Setter Property="BorderBrush" Value="#AAEF4444" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.choice-highlight /template/ ContentPresenter">
            <Setter Property="Background" Value="#3322C55F" />
        </Style>
    </UserControl.Styles>

    <Border
        Margin="12"
        Padding="16"
        CornerRadius="10"
        Background="#CC1E293B"
        BorderBrush="#668ECAE6"
        BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
            <!-- Tab Control -->
            <Border
                Grid.Row="1"
                Margin="0,0,0,12"
                Padding="5"
                CornerRadius="14"
                Background="#22334155"
                BorderBrush="#33475569"
                BorderThickness="1"
                HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button
                        Classes="tab-btn"
                        Classes.selected="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0}"
                        Content="Flashcards"
                        Command="{Binding SelectTabCommand}"
                        CommandParameter="0" />
                    <Button
                        Classes="tab-btn"
                        Classes.selected="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}"
                        Content="Quiz"
                        Command="{Binding SelectTabCommand}"
                        CommandParameter="1" />
                    <Button
                        Classes="tab-btn"
                        Classes.selected="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2}"
                        Content="Writing"
                        Command="{Binding SelectTabCommand}"
                        CommandParameter="2" />
                    <Button
                        Classes="tab-btn"
                        Classes.selected="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}"
                        Content="MBSP"
                        Command="{Binding SelectTabCommand}"
                        CommandParameter="3" />
                </StackPanel>
            </Border>

            <!-- Top row with search and close button -->
            <Grid
                Grid.Row="0"
                ColumnDefinitions="Auto,*,Auto"
                Margin="0,0,0,12">
                <!-- Mute button -->
                <Button
                    Grid.Column="0"
                    Width="48"
                    Height="48"
                    Classes="icon-btn"
                    CornerRadius="10"
                    ToolTip.Tip="{Binding MuteTooltip}"
                    Command="{Binding ToggleMuteCommand}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                    <Panel Width="28" Height="28">
                        <!-- Speaker icon (always shown) -->
                        <Path
                            Fill="#FFE2E8F0"
                            Stretch="Uniform"
                            Data="M6,4 L6,14 L2,11 L2,7 Z M6,4 L12,1 L12,17 L6,14 Z" />
                        <!-- Muted X overlay -->
                        <Path
                            IsVisible="{Binding IsMuted}"
                            Stroke="#FFEF4444"
                            StrokeThickness="2.5"
                            StrokeLineCap="Round"
                            Stretch="Uniform"
                            Data="M14,6 L18,12 M18,6 L14,12" />
                        <!-- Sound waves (visible when unmuted) -->
                        <Path
                            IsVisible="{Binding IsMuted, Converter={StaticResource BoolNegationConverter}}"
                            Stroke="#FF86EFAC"
                            StrokeThickness="2"
                            StrokeLineCap="Round"
                            Fill="Transparent"
                            Stretch="Uniform"
                            Data="M14,7 Q16,9 14,11 M15.5,5.5 Q19,9 15.5,12.5" />
                    </Panel>
                </Button>

                <!-- Search box at top center -->
                <AutoCompleteBox
                    x:Name="SearchBox"
                    Grid.Column="1"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{Binding SearchResults}"
                    FilterMode="None"
                    Watermark="Search..."
                    VerticalAlignment="Center"
                    IsTextCompletionEnabled="False"
                    Padding="8,6"
                    Margin="0,0,0,0"
                    Width="200"
                    FontSize="19"
                    Background="Transparent">
                    <AutoCompleteBox.ItemTemplate>
                        <DataTemplate DataType="models:FlashcardEntry">
                            <StackPanel>
                                <TextBlock
                                    Text="{Binding Danish}"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24" />
                                <TextBlock
                                    Text="{Binding English}"
                                    FontSize="18"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                        </DataTemplate>
                    </AutoCompleteBox.ItemTemplate>
                </AutoCompleteBox>

                <!-- Placeholder for symmetry -->
                <Panel Grid.Column="2" Width="38" Height="38" />
            </Grid>

            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="10">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                        <Binding Path="IsFlashcardPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="{Binding CurrentDanish}"
                                    FontSize="46"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24"
                                    HorizontalAlignment="Center" />
                                <ItemsControl
                                    ItemsSource="{Binding CurrentTypes}"
                                    IsVisible="{Binding HasCurrentType}"
                                    HorizontalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="3,2"
                                                Padding="8,3"
                                                CornerRadius="10"
                                                Background="#442563A0"
                                                BorderBrush="#884BA3C7"
                                                BorderThickness="1">
                                                <TextBlock
                                                    Text="{Binding}"
                                                    FontSize="15"
                                                    FontStyle="Italic"
                                                    Foreground="#FF94A3B8"
                                                    VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock
                                    Text="{Binding CurrentConjugation}"
                                    IsVisible="{Binding HasCurrentConjugation}"
                                    FontSize="20"
                                    FontStyle="Italic"
                                    HorizontalAlignment="Center"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Width="46"
                                Height="46"
                                Classes="icon-btn"
                                CornerRadius="10"
                                VerticalAlignment="Top"
                                Command="{Binding PlayDanishWordCommand}">
                                <Path
                                    Width="24" Height="24"
                                    Fill="#FF94D9FF"
                                    Stretch="Uniform"
                                    Data="M4,5 L4,13 L1,11 L1,7 Z M4,5 L10,2 L10,16 L4,13 Z M11,7 Q13,9 11,11 M12,5.5 Q15,9 12,12.5" />
                            </Button>
                        </Grid>

                        <TextBlock
                            Text="{Binding CurrentEnglish}"
                            IsVisible="{Binding HasFlashcards}"
                            FontSize="32"
                            Foreground="#FFE2E8F0"
                            HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1"
                    IsVisible="{Binding HasCurrentExampleDanish}">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock
                                Grid.Column="0"
                                FontSize="22"
                                TextWrapping="Wrap"
                                Foreground="#FFCBD5E1">
                                <Run Text="{Binding HighlightedExampleDanish.BeforeWord}" FontSize="22" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.HighlightedWord}"
                                    TextDecorations="Underline"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24"
                                    FontSize="22" />
                                <Run Text="{Binding HighlightedExampleDanish.AfterWord}" FontSize="22" />
                            </TextBlock>
                            <Button
                                Grid.Column="1"
                                Width="42"
                                Height="42"
                                Classes="icon-btn"
                                CornerRadius="8"
                                VerticalAlignment="Top"
                                Command="{Binding PlayDanishExampleCommand}">
                                <Path
                                    Width="22" Height="22"
                                    Fill="#FF94D9FF"
                                    Stretch="Uniform"
                                    Data="M4,5 L4,13 L1,11 L1,7 Z M4,5 L10,2 L10,16 L4,13 Z M11,7 Q13,9 11,11 M12,5.5 Q15,9 12,12.5" />
                            </Button>
                        </Grid>
                        <TextBlock
                            FontSize="22"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleDanish.FullText}"
                            IsVisible="{Binding HighlightedExampleDanish.IsFullTextOnly}"/>
                        <!-- Separator -->
                        <Rectangle
                            IsVisible="{Binding HasCurrentExampleEnglish}"
                            Height="1"
                            HorizontalAlignment="Center"
                            Width="200"
                            Margin="0,8,0,8"
                            Fill="#66888888" />
                        <TextBlock
                            FontSize="22"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            IsVisible="{Binding HasCurrentExampleEnglish}">
                            <Run Text="{Binding HighlightedExampleEnglish.BeforeWord}" FontSize="22" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.HighlightedWord}"
                                TextDecorations="Underline"
                                FontWeight="SemiBold"
                                FontSize="22" />
                            <Run Text="{Binding HighlightedExampleEnglish.AfterWord}" FontSize="22" />
                        </TextBlock>
                        <TextBlock
                            FontSize="22"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleEnglish.FullText}"
                            IsVisible="{Binding HighlightedExampleEnglish.IsFullTextOnly}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="8"
                IsVisible="{Binding IsAddRecordPage}">
                <TextBlock Text="Add flashcard" FontSize="24" FontWeight="SemiBold" Foreground="White" />
                <TextBox Text="{Binding NewDanish}" Watermark="Danish" FontSize="19" />
                <TextBox Text="{Binding NewEnglish}" Watermark="English" FontSize="19" />
                <TextBox Text="{Binding NewType}" Watermark="Type (optional)" FontSize="19" />
                <TextBox Text="{Binding NewConjugation}" Watermark="Conjugation (optional)" AcceptsReturn="True" TextWrapping="Wrap" Height="65" FontSize="19" />
                <TextBox Text="{Binding NewExampleDanish}" Watermark="Example Danish (optional)" AcceptsReturn="True" TextWrapping="Wrap" Height="65" FontSize="19" />
                <TextBox Text="{Binding NewExampleEnglish}" Watermark="Example English (optional)" AcceptsReturn="True" TextWrapping="Wrap" Height="65" FontSize="19" />
                <TextBox Text="{Binding NewContextualTip}" Watermark="Contextual tip (optional)" AcceptsReturn="True" TextWrapping="Wrap" Height="65" FontSize="19" />
                <TextBlock
                    Text="{Binding ValidationMessage}"
                    IsVisible="{Binding HasValidationMessage}"
                    TextWrapping="Wrap"
                    Foreground="#FFFCA5A5"
                    FontSize="18" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="Cancel" FontSize="19" Command="{Binding CancelAddRecordCommand}" />
                    <Button Content="Save" FontSize="19" Command="{Binding SaveNewRecordCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- Quiz Page (Empty) -->
            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="10"
                IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}">
                <TextBlock
                    Text="Quiz Page"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="White"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Writing Page -->
            <Grid
                x:Name="WritingGrid"
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="*,*">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </Grid.IsVisible>

                <!-- Danish Writing -->
                <Border
                    x:Name="DanishWritingBorder"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,6,0,5"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock
                            Grid.Row="0"
                            Text="{Binding CurrentDanishWritingTitle}"
                            FontSize="16"
                            Foreground="#FFFBBF24"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4" />
                        <ScrollViewer
                            x:Name="DanishWritingScroller"
                            Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                            <TextBlock
                                x:Name="DanishWritingTextBlock"
                                FontSize="20"
                                Foreground="#FFCBD5E1"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- English Writing -->
                <Border
                    x:Name="EnglishWritingBorder"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,5,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock
                            Grid.Row="0"
                            Text="{Binding CurrentEnglishWritingTitle}"
                            FontSize="16"
                            Foreground="#FFFBBF24"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4" />
                        <ScrollViewer
                            x:Name="EnglishWritingScroller"
                            Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                            <TextBlock
                                Text="{Binding CurrentEnglishWriting}"
                                FontSize="20"
                                Foreground="#FFCBD5E1"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Writing Page Bottom Buttons (nav) -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="22" FontWeight="SemiBold"
                        Content="◀" Command="{Binding PreviousWritingCommand}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="22" FontWeight="SemiBold"
                        Content="▶" Command="{Binding NextWritingCommand}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Writing Page Edit/Add Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button Width="50" Height="50" CornerRadius="25"
                        Classes="icon-btn"
                        Command="{Binding ShowEditWritingCommand}">
                    <Path
                        Width="22" Height="22"
                        Fill="#FFFBBF24"
                        Stretch="Uniform"
                        Data="M12,2 L14,4 L5,13 L2,14 L3,11 Z M13,3 L15,5" />
                </Button>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="26" FontWeight="Bold"
                        Content="+" Command="{Binding ShowAddWritingCommand}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Add Writing Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="Auto,Auto,*,Auto,*,Auto,Auto"
                IsVisible="{Binding IsAddWritingPage}">
                <TextBlock
                    Grid.Row="0"
                    Text="Add writing exercise"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Margin="0,0,0,8" />

                <TextBox
                    Grid.Row="1"
                    Text="{Binding NewWritingDanishTitle}"
                    Watermark="Danish title (optional)"
                    FontSize="19"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Grid.Row="2"
                    Text="{Binding NewWritingDanish}"
                    Watermark="Danish text"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    FontSize="19"
                    Margin="0,0,0,8"
                    VerticalAlignment="Stretch" />

                <TextBox
                    Grid.Row="3"
                    Text="{Binding NewWritingEnglishTitle}"
                    Watermark="English title (optional)"
                    FontSize="19"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Grid.Row="4"
                    Text="{Binding NewWritingEnglish}"
                    Watermark="English text"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    FontSize="19"
                    Margin="0,0,0,8"
                    VerticalAlignment="Stretch" />

                <TextBlock
                    Grid.Row="5"
                    Text="{Binding ValidationMessage}"
                    IsVisible="{Binding HasValidationMessage}"
                    TextWrapping="Wrap"
                    Foreground="#FFFCA5A5"
                    FontSize="18" />

                <StackPanel
                    Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <Button Content="Cancel" FontSize="19" Command="{Binding CancelAddWritingCommand}" />
                    <Button Content="Save" FontSize="19" Command="{Binding SaveNewWritingCommand}" />
                </StackPanel>
            </Grid>

            <!-- MBSP Quiz Page -->
            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="12">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>

                <!-- Question -->
                <Border
                    Padding="16"
                    CornerRadius="14"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock
                            Text="{Binding CurrentMbspQuestionText}"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="#FFE2E8F0"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            TextAlignment="Center" />
                        <TextBlock
                            Text="{Binding CurrentMbspQuestionEnglish}"
                            FontSize="18"
                            FontStyle="Italic"
                            Foreground="#FF94A3B8"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            TextAlignment="Center">
                            <TextBlock.IsVisible>
                                <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                                    <Binding Path="HasCurrentMbspQuestionEnglish" />
                                    <Binding Path="MbspShowEnglish" />
                                </MultiBinding>
                            </TextBlock.IsVisible>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Choice A -->
                <Button
                    Classes.choice-correct="{Binding MbspChoiceAResult, Converter={StaticResource EqualityConverter}, ConverterParameter=correct}"
                    Classes.choice-wrong="{Binding MbspChoiceAResult, Converter={StaticResource EqualityConverter}, ConverterParameter=wrong}"
                    Classes.choice-highlight="{Binding MbspChoiceAResult, Converter={StaticResource EqualityConverter}, ConverterParameter=highlight}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="14,14"
                    CornerRadius="12"
                    Command="{Binding SelectMbspChoiceCommand}"
                    CommandParameter="A"
                    IsEnabled="{Binding MbspSelectedChoice, Converter={x:Static ObjectConverters.IsNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="34" Height="34" CornerRadius="17" Background="#443B82F6" BorderBrush="#664BA3C7" BorderThickness="1">
                            <TextBlock Text="A" FontSize="16" FontWeight="Bold" Foreground="#FFE2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding CurrentMbspChoiceA}" FontSize="20" Foreground="#FFE2E8F0" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <!-- Choice B -->
                <Button
                    Classes.choice-correct="{Binding MbspChoiceBResult, Converter={StaticResource EqualityConverter}, ConverterParameter=correct}"
                    Classes.choice-wrong="{Binding MbspChoiceBResult, Converter={StaticResource EqualityConverter}, ConverterParameter=wrong}"
                    Classes.choice-highlight="{Binding MbspChoiceBResult, Converter={StaticResource EqualityConverter}, ConverterParameter=highlight}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="14,14"
                    CornerRadius="12"
                    Command="{Binding SelectMbspChoiceCommand}"
                    CommandParameter="B"
                    IsEnabled="{Binding MbspSelectedChoice, Converter={x:Static ObjectConverters.IsNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="34" Height="34" CornerRadius="17" Background="#443B82F6" BorderBrush="#664BA3C7" BorderThickness="1">
                            <TextBlock Text="B" FontSize="16" FontWeight="Bold" Foreground="#FFE2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding CurrentMbspChoiceB}" FontSize="20" Foreground="#FFE2E8F0" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <!-- Choice C (only shown when present) -->
                <Button
                    Classes.choice-correct="{Binding MbspChoiceCResult, Converter={StaticResource EqualityConverter}, ConverterParameter=correct}"
                    Classes.choice-wrong="{Binding MbspChoiceCResult, Converter={StaticResource EqualityConverter}, ConverterParameter=wrong}"
                    Classes.choice-highlight="{Binding MbspChoiceCResult, Converter={StaticResource EqualityConverter}, ConverterParameter=highlight}"
                    IsVisible="{Binding CurrentMbspHasChoiceC}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="14,14"
                    CornerRadius="12"
                    Command="{Binding SelectMbspChoiceCommand}"
                    CommandParameter="C"
                    IsEnabled="{Binding MbspSelectedChoice, Converter={x:Static ObjectConverters.IsNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="34" Height="34" CornerRadius="17" Background="#443B82F6" BorderBrush="#664BA3C7" BorderThickness="1">
                            <TextBlock Text="C" FontSize="16" FontWeight="Bold" Foreground="#FFE2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding CurrentMbspChoiceC}" FontSize="20" Foreground="#FFE2E8F0" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>

                <!-- Feedback -->
                <TextBlock
                    Text="{Binding MbspAnswerFeedback}"
                    IsVisible="{Binding MbspHasFeedback}"
                    FontSize="20"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Foreground="#FF86EFAC" />
            </StackPanel>

            <!-- MBSP Add/Edit Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsAddMbspPage" />
                    </MultiBinding>
                </Grid.IsVisible>

                <TextBlock Grid.Row="0" Text="Add / Edit Question" FontSize="22" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8" />

                <TextBox
                    Grid.Row="1"
                    Text="{Binding NewMbspQuestion}"
                    Watermark="Question (Danish)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    FontSize="19"
                    Height="80"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Grid.Row="2"
                    Text="{Binding NewMbspQuestionEnglish}"
                    Watermark="Question English (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    FontSize="19"
                    Height="65"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch" />

                <!-- Choice A with radio button -->
                <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                    <RadioButton Grid.Column="0" GroupName="MbspCorrect"
                                 IsChecked="{Binding NewMbspCorrectChoiceIsA, Mode=TwoWay}"
                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding NewMbspChoiceA}" Watermark="Choice A" FontSize="19" HorizontalAlignment="Stretch" />
                </Grid>

                <!-- Choice B with radio button -->
                <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                    <RadioButton Grid.Column="0" GroupName="MbspCorrect"
                                 IsChecked="{Binding NewMbspCorrectChoiceIsB, Mode=TwoWay}"
                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding NewMbspChoiceB}" Watermark="Choice B" FontSize="19" HorizontalAlignment="Stretch" />
                </Grid>

                <!-- Choice C with radio button (optional) -->
                <Grid Grid.Row="5" ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                    <RadioButton Grid.Column="0" GroupName="MbspCorrect"
                                 IsChecked="{Binding NewMbspCorrectChoiceIsC, Mode=TwoWay}"
                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding NewMbspChoiceC}" Watermark="Choice C (optional)" FontSize="19" HorizontalAlignment="Stretch" />
                </Grid>

                <StackPanel Grid.Row="6" Spacing="6">
                    <TextBlock
                        Text="{Binding ValidationMessage}"
                        IsVisible="{Binding HasValidationMessage}"
                        TextWrapping="Wrap"
                        Foreground="#FFFCA5A5"
                        FontSize="18" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Cancel" FontSize="19" Command="{Binding CancelMbspCommand}" />
                        <Button Content="Save" FontSize="19" Command="{Binding SaveMbspCommand}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- MBSP Bottom Nav Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="22" FontWeight="SemiBold"
                        Content="◀" Command="{Binding PreviousMbspCommand}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                <Button Width="50" Height="50" CornerRadius="25" FontSize="22" FontWeight="SemiBold"
                        Content="▶" Command="{Binding NextMbspCommand}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            </StackPanel>

            <!-- MBSP Edit/Add Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,0,0"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button Width="50" Height="50" CornerRadius="25"
                        Classes="icon-btn"
                        Command="{Binding ShowEditMbspCommand}">
                    <Path Width="22" Height="22" Fill="#FFFBBF24" Stretch="Uniform"
                          Data="M12,2 L14,4 L5,13 L2,14 L3,11 Z M13,3 L15,5" />
                </Button>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="26" FontWeight="Bold"
                        Content="+" Command="{Binding ShowAddMbspCommand}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            </StackPanel>

            <!-- MBSP Eng Toggle Switch (bottom-left corner) -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Spacing="4">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <TextBlock
                    Text="Eng"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"
                    Foreground="#FFE2E8F0" />
                <ToggleSwitch
                    IsChecked="{Binding MbspShowEnglish, Mode=TwoWay}"
                    OnContent=""
                    OffContent=""
                    VerticalAlignment="Center" />
            </StackPanel>

            <Border
                Grid.Row="5"
                Margin="0,8,0,0"
                Padding="8,6"
                CornerRadius="8"
                Background="#22F59E0B">
                <Border.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="HasCurrentContextualTip" />
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Border.IsVisible>
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="*" FontSize="18" VerticalAlignment="Top" Margin="0,0,6,0" />
                    <TextBlock Grid.Column="1" Text="{Binding CurrentContextualTip}" FontSize="18" TextWrapping="Wrap" Foreground="#FFFBBF24" />
                </Grid>
            </Border>

            <!-- Add Flashcard -->
            <Button
                Grid.Row="6"
                Width="50" Height="50"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                CornerRadius="25"
                FontSize="26" FontWeight="Bold"
                Content="+"
                Command="{Binding ShowAddRecordCommand}"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
                <Button.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Edit Flashcard -->
            <Button
                Grid.Row="6"
                Width="50" Height="50"
                Margin="0,0,62,0"
                Classes="icon-btn"
                CornerRadius="25"
                Command="{Binding ShowEditRecordCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom">
                <Path
                    Width="22" Height="22"
                    Fill="#FFFBBF24"
                    Stretch="Uniform"
                    Data="M12,2 L14,4 L5,13 L2,14 L3,11 Z M13,3 L15,5" />
                <Button.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="HasFlashcards" />
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Previous/Next Flashcard -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="22" FontWeight="SemiBold"
                        Content="◀" Command="{Binding PreviousCardCommand}"
                        IsEnabled="{Binding CanNavigateFlashcards}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="22" FontWeight="SemiBold"
                        Content="▶" Command="{Binding NextCardCommand}"
                        IsEnabled="{Binding CanNavigateFlashcards}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Auto / Pause Rotate Flashcard -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="18" FontWeight="SemiBold"
                        Content="▶" Command="{Binding PlayCommand}" IsEnabled="{Binding IsRotationPaused}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Width="50" Height="50" CornerRadius="25" FontSize="18" FontWeight="SemiBold"
                        Content="||" Command="{Binding PauseCommand}" IsEnabled="{Binding IsRotationPlaying}"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
