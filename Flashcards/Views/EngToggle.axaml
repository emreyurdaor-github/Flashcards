<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Flashcards.Views.EngToggle">

    <!--
        Layout: [Label]  [OFF | ON]
        OFF active = bright red, ON active = bright green.
        Click anywhere to toggle.
    -->
    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                Spacing="6">

        <!-- Label on the left -->
        <TextBlock x:Name="LabelText"
                   Text="Eng"
                   VerticalAlignment="Center"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#B0B8C5"/>

        <!-- Track -->
        <Border x:Name="Track"
                Height="28"
                Width="68"
                CornerRadius="2"
                ClipToBounds="True"
                BorderThickness="1"
                BorderBrush="#444C56"
                VerticalAlignment="Center">
            <Grid ColumnDefinitions="*,*">

                <!-- OFF segment -->
                <Border x:Name="OffSegment"
                        Grid.Column="0"
                        CornerRadius="0"
                        Background="#3C3F41">
                    <TextBlock x:Name="OffText"
                               Text="OFF"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#6B7280"/>
                </Border>

                <!-- ON segment -->
                <Border x:Name="OnSegment"
                        Grid.Column="1"
                        CornerRadius="0"
                        Background="#3C3F41">
                    <TextBlock x:Name="OnText"
                               Text="ON"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#6B7280"/>
                </Border>

            </Grid>
        </Border>
    </StackPanel>
</UserControl>