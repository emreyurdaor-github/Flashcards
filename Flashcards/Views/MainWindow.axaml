<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Flashcards.ViewModels"
    xmlns:models="using:Flashcards.Models"
    xmlns:converters="using:Flashcards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="Flashcards.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Title="Flashcards"
    Icon="/Assets/app.ico"
    Width="440"
    Height="670"
    CanResize="False"
    ShowInTaskbar="False"
    SystemDecorations="None"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    Background="Transparent"
    TransparencyLevelHint="Transparent">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:MultiBooleanAndConverter x:Key="MultiBooleanAndConverter" />
        <converters:EqualityConverter x:Key="EqualityConverter" />
    </Window.Resources>

    <Border
        Margin="12"
        Padding="16"
        CornerRadius="10"
        Background="#CC1E293B"
        BorderBrush="#668ECAE6"
        BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
            <!-- Tab Control -->
            <TabControl
                Grid.Row="1"
                SelectedIndex="{Binding SelectedTabIndex}"
                Margin="0,0,0,12"
                HorizontalAlignment="Center"
                Height="28">
                <TabItem Padding="6,2" BorderBrush="Gray" BorderThickness="1">
                    <TabItem.Header>
                        <TextBlock Text="Flashcards" FontSize="14" VerticalAlignment="Center" />
                    </TabItem.Header>
                </TabItem>
                <TabItem Padding="6,2" BorderBrush="Gray" BorderThickness="1">
                    <TabItem.Header>
                        <TextBlock Text="Quiz" FontSize="14" VerticalAlignment="Center" />
                    </TabItem.Header>
                </TabItem>
                <TabItem Padding="6,2" BorderBrush="Gray" BorderThickness="1">
                    <TabItem.Header>
                        <TextBlock Text="Writing" FontSize="14" VerticalAlignment="Center" />
                    </TabItem.Header>
                </TabItem>
            </TabControl>

            <!-- Top row with search and close button -->
            <Grid
                Grid.Row="0"
                ColumnDefinitions="Auto,*,Auto"
                Margin="0,0,0,12">
                <!-- Mute button -->
                <Button
                    Grid.Column="0"
                    Width="22"
                    Height="22"
                    Padding="0"
                    CornerRadius="6"
                    FontSize="14"
                    FontWeight="Bold"
                    Content="{Binding MuteIcon}"
                    ToolTip.Tip="{Binding MuteTooltip}"
                    Command="{Binding ToggleMuteCommand}"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,0,8,0" />

                <!-- Search box at top center -->
                <AutoCompleteBox
                    x:Name="SearchBox"
                    Grid.Column="1"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{Binding SearchResults}"
                    FilterMode="None"
                    Watermark="🔍"
                    VerticalAlignment="Center"
                    IsTextCompletionEnabled="False"
                    Padding="8,6"
                    Margin="0,0,0,0"
                    Width="200"
                    Background="Transparent">
                    <AutoCompleteBox.ItemTemplate>
                        <DataTemplate DataType="models:FlashcardEntry">
                            <StackPanel>
                                <TextBlock
                                    Text="{Binding Danish}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24" />
                                <TextBlock
                                    Text="{Binding English}"
                                    FontSize="12"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                        </DataTemplate>
                    </AutoCompleteBox.ItemTemplate>
                </AutoCompleteBox>



                <!-- Close button at top right -->
                <Button
                    Grid.Column="2"
                    Width="22"
                    Height="22"
                    Padding="0"
                    CornerRadius="6"
                    FontSize="14"
                    FontWeight="Bold"
                    Content="✕"
                    Command="{Binding MinimizeToTrayCommand}"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0" />
            </Grid>

            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="10">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                        <Binding Path="IsFlashcardPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <!-- ...existing flashcard content... -->
                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <StackPanel
                        Spacing="4">
                        <Grid
                            ColumnDefinitions="*,Auto">
                            <StackPanel
                                Grid.Column="0"
                                Spacing="4">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <TextBlock
                                        Text="{Binding CurrentDanish}"
                                        FontSize="30"
                                        FontWeight="SemiBold"
                                        Foreground="#FFFBBF24"
                                        VerticalAlignment="Center" />
                                    <ItemsControl
                                        ItemsSource="{Binding CurrentTypes}"
                                        IsVisible="{Binding HasCurrentType}"
                                        VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="2,2,2,2"
                                                    Padding="5,1"
                                                    CornerRadius="8"
                                                    Background="#442563A0"
                                                    BorderBrush="#884BA3C7"
                                                    BorderThickness="1">
                                                    <TextBlock
                                                        Text="{Binding}"
                                                        FontSize="10"
                                                        FontStyle="Italic"
                                                        Foreground="#FF94A3B8"
                                                        VerticalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock
                                    Text="{Binding CurrentConjugation}"
                                    IsVisible="{Binding HasCurrentConjugation}"
                                    FontSize="12"
                                    FontStyle="Italic"
                                    HorizontalAlignment="Center"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="14"
                                Content="🔊"
                                VerticalAlignment="Top"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding PlayDanishWordCommand}" />
                        </Grid>

                        <TextBlock
                            Text="{Binding CurrentEnglish}"
                            IsVisible="{Binding HasFlashcards}"
                            FontSize="20"
                            Foreground="#FFE2E8F0"
                            HorizontalAlignment="Center" />

                    </StackPanel>
                </Border>

                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1"
                    IsVisible="{Binding HasCurrentExampleDanish}">
                    <StackPanel
                        Spacing="6">
                        <Grid
                            ColumnDefinitions="*,Auto">
                            <TextBlock
                                Grid.Column="0"
                                FontSize="14"
                                TextWrapping="Wrap"
                                Foreground="#FFCBD5E1">
                                <Run
                                    Text="{Binding HighlightedExampleDanish.BeforeWord}"
                                    FontSize="14" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.HighlightedWord}"
                                    TextDecorations="Underline"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24"
                                    FontSize="14" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.AfterWord}"
                                    FontSize="14" />
                            </TextBlock>
                            <Button
                                Grid.Column="1"
                                Width="24"
                                Height="24"
                                Padding="0"
                                CornerRadius="4"
                                FontSize="12"
                                Content="🔊"
                                VerticalAlignment="Top"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding PlayDanishExampleCommand}" />
                        </Grid>
                        <!-- Fallback: Show full text if highlighting failed -->
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleDanish.FullText}"
                            IsVisible="{Binding HighlightedExampleDanish.IsFullTextOnly}"/>
                        <!-- Separator -->
                        <Rectangle
                            IsVisible="{Binding HasCurrentExampleEnglish}"
                            Height="1"
                            HorizontalAlignment="Center"
                            Width="200"
                            Margin="0,6,0,6"
                            Fill="#66888888" />
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            IsVisible="{Binding HasCurrentExampleEnglish}">
                            <Run
                                Text="{Binding HighlightedExampleEnglish.BeforeWord}"
                                FontSize="14" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.HighlightedWord}"
                                TextDecorations="Underline"
                                FontWeight="SemiBold"
                                FontSize="14" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.AfterWord}"
                                FontSize="14" />
                        </TextBlock>
                        <!-- Fallback: Show full text if highlighting failed -->
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleEnglish.FullText}"
                            IsVisible="{Binding HighlightedExampleEnglish.IsFullTextOnly}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="8"
                IsVisible="{Binding IsAddRecordPage}">
                <TextBlock
                    Text="Add flashcard"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White" />

                <TextBox
                    Text="{Binding NewDanish}"
                    Watermark="Danish"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="60"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Text="{Binding NewEnglish}"
                    Watermark="English"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="60"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Text="{Binding NewType}"
                    Watermark="Type (optional)" />

                <TextBox
                    Text="{Binding NewConjugation}"
                    Watermark="Conjugation (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewExampleDanish}"
                    Watermark="Example Danish (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewExampleEnglish}"
                    Watermark="Example English (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewContextualTip}"
                    Watermark="Contextual tip (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBlock
                    Text="{Binding ValidationMessage}"
                    IsVisible="{Binding HasValidationMessage}"
                    TextWrapping="Wrap"
                    Foreground="#FFFCA5A5"
                    FontSize="12" />

                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <Button
                        Content="Cancel"
                        Command="{Binding CancelAddRecordCommand}" />
                    <Button
                        Content="Save"
                        Command="{Binding SaveNewRecordCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- Quiz Page (Empty) -->
            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="10"
                IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}">
                <TextBlock
                    Text="Quiz Page"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Writing Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="*,*">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </Grid.IsVisible>
                <!-- Writing Section 1: Danish Writing -->
                <Border
                    Grid.Row="0"
                    Margin="0,6,0,5"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock
                            Grid.Row="0"
                            Text="Danish Writing"
                            FontSize="12"
                            Foreground="#FFFBBF24"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4" />
                        <ScrollViewer
                            x:Name="DanishWritingScroller"
                            Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                            <TextBlock
                                Text="{Binding CurrentDanishWriting}"
                                FontSize="14"
                                Foreground="#FFCBD5E1"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Writing Section 2: English Writing -->
                <Border
                    Grid.Row="1"
                    Margin="0,5,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock
                            Grid.Row="0"
                            Text="English Writing"
                            FontSize="12"
                            Foreground="#FFFBBF24"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4" />
                        <ScrollViewer
                            x:Name="EnglishWritingScroller"
                            Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                            <TextBlock
                                Text="{Binding CurrentEnglishWriting}"
                                FontSize="14"
                                Foreground="#FFCBD5E1"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Writing Page Bottom Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="◀"
                    Command="{Binding PreviousWritingCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding NextWritingCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Writing Page Edit/Add Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="✎"
                    Command="{Binding ShowEditWritingCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="18"
                    FontWeight="Bold"
                    Content="+"
                    Command="{Binding ShowAddWritingCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Add Writing Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="Auto,*,*,Auto,Auto"
                IsVisible="{Binding IsAddWritingPage}">
                <TextBlock
                    Grid.Row="0"
                    Text="Add writing exercise"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Margin="0,0,0,8" />

                <TextBox
                    Grid.Row="1"
                    Text="{Binding NewWritingDanish}"
                    Watermark="Danish"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Margin="0,0,0,8"
                    VerticalAlignment="Stretch" />

                <TextBox
                    Grid.Row="2"
                    Text="{Binding NewWritingEnglish}"
                    Watermark="English"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Margin="0,0,0,8"
                    VerticalAlignment="Stretch" />

                <TextBlock
                    Grid.Row="3"
                    Text="{Binding ValidationMessage}"
                    IsVisible="{Binding HasValidationMessage}"
                    TextWrapping="Wrap"
                    Foreground="#FFFCA5A5"
                    FontSize="12" />

                <StackPanel
                    Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <Button
                        Content="Cancel"
                        Command="{Binding CancelAddWritingCommand}" />
                    <Button
                        Content="Save"
                        Command="{Binding SaveNewWritingCommand}" />
                </StackPanel>
            </Grid>

            <!-- Contextual Tip -->
            <Border
                Grid.Row="5"
                Margin="0,8,0,0"
                Padding="8,6"
                CornerRadius="8"
                Background="#22F59E0B">
                <Border.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="HasCurrentContextualTip" />
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Border.IsVisible>
                <Grid
                    ColumnDefinitions="Auto,*">
                    <TextBlock
                        Grid.Column="0"
                        Text="💡"
                        FontSize="12"
                        VerticalAlignment="Top"
                        Margin="0,0,6,0" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding CurrentContextualTip}"
                        FontSize="12"
                        TextWrapping="Wrap"
                        Foreground="#FFFBBF24" />
                </Grid>
            </Border>

            <!-- Add Flashcard -->
            <Button
                Grid.Row="6"
                Width="32"
                Height="32"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                CornerRadius="16"
                FontSize="18"
                FontWeight="Bold"
                Content="+"
                Command="{Binding ShowAddRecordCommand}"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
                <Button.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Edit Flashcard -->
            <Button
                Grid.Row="6"
                Width="32"
                Height="32"
                Margin="0,0,44,0"
                CornerRadius="16"
                FontSize="14"
                FontWeight="SemiBold"
                Content="✎"
                Command="{Binding ShowEditRecordCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
                <Button.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="HasFlashcards" />
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Previous/Next Flashcard -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="◀"
                    Command="{Binding PreviousCardCommand}"
                    IsEnabled="{Binding CanNavigateFlashcards}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding NextCardCommand}"
                    IsEnabled="{Binding CanNavigateFlashcards}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Auto / Pause Rotate Flashcard -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding PlayCommand}"
                    IsEnabled="{Binding IsRotationPaused}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Content="⏸"
                    Command="{Binding PauseCommand}"
                    IsEnabled="{Binding IsRotationPlaying}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>

</Window>