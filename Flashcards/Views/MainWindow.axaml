<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Flashcards.ViewModels"
    xmlns:models="using:Flashcards.Models"
    xmlns:converters="using:Flashcards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="Flashcards.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Title="Flashcards"
    Icon="/Assets/app.ico"
    Width="460"
    Height="600"
    CanResize="False"
    ShowInTaskbar="False"
    SystemDecorations="None"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    Background="Transparent"
    TransparencyLevelHint="Transparent">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:MultiBooleanAndConverter x:Key="MultiBooleanAndConverter" />
    </Window.Resources>

    <Border
        Margin="12"
        Padding="16"
        CornerRadius="10"
        Background="#CC1E293B"
        BorderBrush="#668ECAE6"
        BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">
            <!-- Top row with search and close button -->
            <Grid
                Grid.Row="0"
                ColumnDefinitions="Auto,*,Auto"
                Margin="0,0,0,12">
                <!-- Mute button -->
                <Button
                    Grid.Column="0"
                    Width="22"
                    Height="22"
                    Padding="0"
                    CornerRadius="6"
                    FontSize="14"
                    FontWeight="Bold"
                    Content="{Binding MuteIcon}"
                    ToolTip.Tip="{Binding MuteTooltip}"
                    Command="{Binding ToggleMuteCommand}"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,0,8,0" />

                <!-- Search box at top center -->
                <AutoCompleteBox
                    x:Name="SearchBox"
                    Grid.Column="1"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{Binding SearchResults}"
                    FilterMode="None"
                    Watermark="🔍"
                    VerticalAlignment="Center"
                    IsTextCompletionEnabled="False"
                    Padding="8,6"
                    Margin="0,0,0,0"
                    Width="200"
                    Background="Transparent">
                    <AutoCompleteBox.ItemTemplate>
                        <DataTemplate DataType="models:FlashcardEntry">
                            <StackPanel>
                                <TextBlock
                                    Text="{Binding Danish}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24" />
                                <TextBlock
                                    Text="{Binding English}"
                                    FontSize="12"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                        </DataTemplate>
                    </AutoCompleteBox.ItemTemplate>
                </AutoCompleteBox>



                <!-- Close button at top right -->
                <Button
                    Grid.Column="2"
                    Width="22"
                    Height="22"
                    Padding="0"
                    CornerRadius="6"
                    FontSize="14"
                    FontWeight="Bold"
                    Content="✕"
                    Command="{Binding MinimizeToTrayCommand}"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0" />
            </Grid>

            <StackPanel
                Grid.Row="3"
                Margin="0,12,0,0"
                Spacing="10"
                IsVisible="{Binding IsFlashcardPage}">
                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <StackPanel
                        Spacing="4">
                        <Grid
                            ColumnDefinitions="*,Auto">
                            <StackPanel
                                Grid.Column="0"
                                Spacing="4">
                                <TextBlock
                                    Text="{Binding CurrentDanish}"
                                    FontSize="30"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    Text="{Binding CurrentConjugation}"
                                    IsVisible="{Binding HasCurrentConjugation}"
                                    FontSize="12"
                                    FontStyle="Italic"
                                    HorizontalAlignment="Center"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                Padding="0"
                                CornerRadius="6"
                                FontSize="14"
                                Content="🔊"
                                VerticalAlignment="Top"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding PlayDanishWordCommand}" />
                        </Grid>

                        <TextBlock
                            Text="{Binding CurrentEnglish}"
                            IsVisible="{Binding HasFlashcards}"
                            FontSize="20"
                            Foreground="#FFE2E8F0"
                            HorizontalAlignment="Center" />

                    </StackPanel>
                </Border>

                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1"
                    IsVisible="{Binding HasCurrentExampleDanish}">
                    <StackPanel
                        Spacing="6">
                        <Grid
                            ColumnDefinitions="*,Auto">
                            <TextBlock
                                Grid.Column="0"
                                FontSize="14"
                                TextWrapping="Wrap"
                                Foreground="#FFCBD5E1">
                                <Run
                                    Text="DA : "
                                    FontStyle="Italic"
                                    FontSize="12" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.BeforeWord}"
                                    FontSize="14" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.HighlightedWord}"
                                    TextDecorations="Underline"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24"
                                    FontSize="14" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.AfterWord}"
                                    FontSize="14" />
                            </TextBlock>
                            <Button
                                Grid.Column="1"
                                Width="24"
                                Height="24"
                                Padding="0"
                                CornerRadius="4"
                                FontSize="12"
                                Content="🔊"
                                VerticalAlignment="Top"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding PlayDanishExampleCommand}" />
                        </Grid>
                        <!-- Fallback: Show full text if highlighting failed -->
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleDanish.FullText}"
                            IsVisible="{Binding HighlightedExampleDanish.IsFullTextOnly}"/>
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            IsVisible="{Binding HasCurrentExampleEnglish}">
                            <Run
                                Text="EN : "
                                FontStyle="Italic"
                                FontSize="12" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.BeforeWord}"
                                FontSize="14" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.HighlightedWord}"
                                TextDecorations="Underline"
                                FontWeight="SemiBold"
                                FontSize="14" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.AfterWord}"
                                FontSize="14" />
                        </TextBlock>
                        <!-- Fallback: Show full text if highlighting failed -->
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleEnglish.FullText}"
                            IsVisible="{Binding HighlightedExampleEnglish.IsFullTextOnly}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel
                Grid.Row="3"
                Margin="0,12,0,0"
                Spacing="8"
                IsVisible="{Binding IsAddRecordPage}">
                <TextBlock
                    Text="Add flashcard"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White" />

                <TextBox
                    Text="{Binding NewDanish}"
                    Watermark="Danish" />

                <TextBox
                    Text="{Binding NewEnglish}"
                    Watermark="English" />

                <TextBox
                    Text="{Binding NewConjugation}"
                    Watermark="Conjugation (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewExampleDanish}"
                    Watermark="Example Danish (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewExampleEnglish}"
                    Watermark="Example English (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewContextualTip}"
                    Watermark="Contextual tip (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBlock
                    Text="{Binding ValidationMessage}"
                    IsVisible="{Binding HasValidationMessage}"
                    TextWrapping="Wrap"
                    Foreground="#FFFCA5A5"
                    FontSize="12" />

                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <Button
                        Content="Cancel"
                        Command="{Binding CancelAddRecordCommand}" />
                    <Button
                        Content="Save"
                        Command="{Binding SaveNewRecordCommand}" />
                </StackPanel>
            </StackPanel>

            <Border
                Grid.Row="4"
                Margin="0,8,0,0"
                Padding="8,6"
                CornerRadius="8"
                Background="#22F59E0B">
                <Border.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="HasCurrentContextualTip" />
                        <Binding Path="IsFlashcardPage" />
                    </MultiBinding>
                </Border.IsVisible>
                <Grid
                    ColumnDefinitions="Auto,*">
                    <TextBlock
                        Grid.Column="0"
                        Text="💡"
                        FontSize="12"
                        VerticalAlignment="Top"
                        Margin="0,0,6,0" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding CurrentContextualTip}"
                        FontSize="12"
                        TextWrapping="Wrap"
                        Foreground="#FFFBBF24" />
                </Grid>
            </Border>

            <Button
                Grid.Row="5"
                Width="32"
                Height="32"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                CornerRadius="16"
                FontSize="18"
                FontWeight="Bold"
                Content="+"
                Command="{Binding ShowAddRecordCommand}"
                IsVisible="{Binding IsFlashcardPage}"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"/>

            <Button
                Grid.Row="5"
                Width="32"
                Height="32"
                Margin="0,0,44,0"
                CornerRadius="16"
                FontSize="14"
                FontWeight="SemiBold"
                Content="✎"
                Command="{Binding ShowEditRecordCommand}"
                IsVisible="{Binding HasFlashcards}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"/>

            <StackPanel
                Grid.Row="5"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="◀"
                    Command="{Binding PreviousCardCommand}"
                    IsVisible="{Binding IsFlashcardPage}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding NextCardCommand}"
                    IsVisible="{Binding IsFlashcardPage}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel
                Grid.Row="5"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                Spacing="8">
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding PlayCommand}"
                    IsEnabled="{Binding IsRotationPaused}"
                    IsVisible="{Binding IsFlashcardPage}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Content="⏸"
                    Command="{Binding PauseCommand}"
                    IsEnabled="{Binding IsRotationPlaying}"
                    IsVisible="{Binding IsFlashcardPage}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>

</Window>