<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Flashcards.ViewModels"
    xmlns:models="using:Flashcards.Models"
    xmlns:converters="using:Flashcards.Converters"
    xmlns:views="using:Flashcards.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="Flashcards.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Title="Flashcards"
    Icon="/Assets/app.ico"
    Width="520"
    Height="680"
    CanResize="False"
    ShowInTaskbar="False"
    SystemDecorations="None"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    Background="Transparent"
    TransparencyLevelHint="Transparent">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:MultiBooleanAndConverter x:Key="MultiBooleanAndConverter" />
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
    </Window.Resources>

    <Window.Styles>
        <!-- Icon button base style -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
        <Style Selector="Button.icon-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#55FFFFFF" />
        </Style>
        <Style Selector="Button.icon-btn:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.35" />
        </Style>
        <!-- MBSP choice result styles -->
        <Style Selector="Button.choice-correct /template/ ContentPresenter">
            <Setter Property="Background" Value="#4422C55F" />
        </Style>
        <Style Selector="Button.choice-correct">
            <Setter Property="BorderBrush" Value="#AA22C55F" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.choice-wrong /template/ ContentPresenter">
            <Setter Property="Background" Value="#44EF4444" />
        </Style>
        <Style Selector="Button.choice-wrong">
            <Setter Property="BorderBrush" Value="#AAEF4444" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.choice-highlight /template/ ContentPresenter">
            <Setter Property="Background" Value="#3322C55F" />
        </Style>
        <Style Selector="Button.choice-highlight">
            <Setter Property="BorderBrush" Value="#8822C55F" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </Window.Styles>

    <Border
        Margin="12"
        Padding="16"
        CornerRadius="10"
        Background="#1E293B"
        BorderBrush="#668ECAE6"
        BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
            <!-- Tab ComboBox row -->
            <Grid
                Grid.Row="1"
                ColumnDefinitions="Auto,*,Auto"
                Margin="0,0,0,12">
            <ComboBox
                Grid.Column="0"
                HorizontalAlignment="Left"
                SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="#FFE2E8F0"
                Background="#22334155"
                BorderBrush="#33475569"
                BorderThickness="1"
                Padding="10,8"
                MinWidth="200">
                <ComboBoxItem Content="Flashcards" />
                <ComboBoxItem Content="Quiz" />
                <ComboBoxItem Content="Writing" />
                <ComboBoxItem Content="MedborgerskabsPrøven" />
            </ComboBox>

            <!-- Period filter ComboBox (only visible on MBSP tab) -->
            <ComboBox
                Grid.Column="2"
                HorizontalAlignment="Right"
                IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=3}"
                ItemsSource="{Binding MbspPeriods}"
                SelectedItem="{Binding SelectedMbspPeriod, Mode=TwoWay}"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="#FFE2E8F0"
                Background="#22334155"
                BorderBrush="#33475569"
                BorderThickness="1"
                Padding="8,6"
                MinWidth="130" />
            </Grid>

            <!-- Top row with search and close button -->
            <Grid
                Grid.Row="0"
                ColumnDefinitions="Auto,*,Auto"
                Margin="0,0,0,12">
                <!-- Mute button -->
                <Button
                    Grid.Column="0"
                    Width="28"
                    Height="28"
                    Classes="icon-btn"
                    CornerRadius="6"
                    ToolTip.Tip="{Binding MuteTooltip}"
                    Command="{Binding ToggleMuteCommand}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                    <Panel Width="18" Height="18">
                        <!-- Speaker icon (always shown) -->
                        <Path
                            Fill="#FFE2E8F0"
                            Stretch="Uniform"
                            Data="M6,4 L6,14 L2,11 L2,7 Z M6,4 L12,1 L12,17 L6,14 Z M14,7 Q16,9 14,11" />
                        <!-- Muted X overlay -->
                        <Path
                            IsVisible="{Binding IsMuted}"
                            Stroke="#FFEF4444"
                            StrokeThickness="2"
                            StrokeLineCap="Round"
                            Stretch="Uniform"
                            Data="M14,6 L18,12 M18,6 L14,12" />
                        <!-- Sound waves (visible when unmuted) -->
                        <Path
                            IsVisible="{Binding IsMuted, Converter={StaticResource BoolNegationConverter}}"
                            Stroke="#FF86EFAC"
                            StrokeThickness="1.5"
                            StrokeLineCap="Round"
                            Fill="Transparent"
                            Stretch="Uniform"
                            Data="M14,7 Q16,9 14,11 M15.5,5.5 Q19,9 15.5,12.5" />
                    </Panel>
                </Button>

                <!-- Search box at top center -->
                <AutoCompleteBox
                    x:Name="SearchBox"
                    Grid.Column="1"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{Binding SearchResults}"
                    FilterMode="None"
                    Watermark="🔍"
                    VerticalAlignment="Center"
                    IsTextCompletionEnabled="False"
                    Padding="8,6"
                    Margin="0,0,0,0"
                    Width="200"
                    Background="Transparent">
                    <AutoCompleteBox.ItemTemplate>
                        <DataTemplate DataType="models:FlashcardEntry">
                            <StackPanel>
                                <TextBlock
                                    Text="{Binding Danish}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24" />
                                <TextBlock
                                    Text="{Binding English}"
                                    FontSize="12"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                        </DataTemplate>
                    </AutoCompleteBox.ItemTemplate>
                </AutoCompleteBox>



                <!-- Buttons at top right -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
                    <!-- Resize button -->
                    <Button
                        x:Name="ResizeButton"
                        Width="22"
                        Height="22"
                        Padding="0"
                        CornerRadius="6"
                        FontSize="12"
                        FontWeight="Bold"
                        Content="⤢"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnResizeButtonClick" />
                    <!-- Close button -->
                    <Button
                        Width="22"
                        Height="22"
                        Padding="0"
                        CornerRadius="6"
                        FontSize="14"
                        FontWeight="Bold"
                        Content="✕"
                        Command="{Binding MinimizeToTrayCommand}"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0" />
                </StackPanel>
            </Grid>

            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="10">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                        <Binding Path="IsFlashcardPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <!-- ...existing flashcard content... -->
                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <StackPanel
                        Spacing="4">
                        <Grid
                            ColumnDefinitions="*,Auto">
                            <StackPanel
                                Grid.Column="0"
                                Spacing="4">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <TextBlock
                                        Text="{Binding CurrentDanish}"
                                        FontSize="30"
                                        FontWeight="SemiBold"
                                        Foreground="#FFFBBF24"
                                        VerticalAlignment="Center" />
                                    <ItemsControl
                                        ItemsSource="{Binding CurrentTypes}"
                                        IsVisible="{Binding HasCurrentType}"
                                        VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="2,2,2,2"
                                                    Padding="5,1"
                                                    CornerRadius="8"
                                                    Background="#442563A0"
                                                    BorderBrush="#884BA3C7"
                                                    BorderThickness="1">
                                                    <TextBlock
                                                        Text="{Binding}"
                                                        FontSize="10"
                                                        FontStyle="Italic"
                                                        Foreground="#FF94A3B8"
                                                        VerticalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock
                                    Text="{Binding CurrentConjugation}"
                                    IsVisible="{Binding HasCurrentConjugation}"
                                    FontSize="12"
                                    FontStyle="Italic"
                                    HorizontalAlignment="Center"
                                    Foreground="#FFCBD5E1" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Width="30"
                                Height="30"
                                Classes="icon-btn"
                                CornerRadius="6"
                                VerticalAlignment="Top"
                                Command="{Binding PlayDanishWordCommand}">
                                <Path
                                    Width="16" Height="16"
                                    Fill="#FF94D9FF"
                                    Stretch="Uniform"
                                    Data="M4,5 L4,13 L1,11 L1,7 Z M4,5 L10,2 L10,16 L4,13 Z M11,7 Q13,9 11,11 M12,5.5 Q15,9 12,12.5" />
                            </Button>
                        </Grid>

                        <TextBlock
                            Text="{Binding CurrentEnglish}"
                            IsVisible="{Binding HasFlashcards}"
                            FontSize="20"
                            Foreground="#FFE2E8F0"
                            HorizontalAlignment="Center" />

                    </StackPanel>
                </Border>

                <Border
                    Margin="0,6,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1"
                    IsVisible="{Binding HasCurrentExampleDanish}">
                    <StackPanel
                        Spacing="6">
                        <Grid
                            ColumnDefinitions="*,Auto">
                            <TextBlock
                                Grid.Column="0"
                                FontSize="14"
                                TextWrapping="Wrap"
                                Foreground="#FFCBD5E1">
                                <Run
                                    Text="{Binding HighlightedExampleDanish.BeforeWord}"
                                    FontSize="16" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.HighlightedWord}"
                                    TextDecorations="Underline"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBBF24"
                                    FontSize="16" />
                                <Run
                                    Text="{Binding HighlightedExampleDanish.AfterWord}"
                                    FontSize="16" />
                            </TextBlock>
                            <Button
                                Grid.Column="1"
                                Width="26"
                                Height="26"
                                Classes="icon-btn"
                                CornerRadius="4"
                                VerticalAlignment="Top"
                                Command="{Binding PlayDanishExampleCommand}">
                                <Path
                                    Width="14" Height="14"
                                    Fill="#FF94D9FF"
                                    Stretch="Uniform"
                                    Data="M4,5 L4,13 L1,11 L1,7 Z M4,5 L10,2 L10,16 L4,13 Z M11,7 Q13,9 11,11 M12,5.5 Q15,9 12,12.5" />
                            </Button>
                        </Grid>
                        <!-- Fallback: Show full text if highlighting failed -->
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleDanish.FullText}"
                            IsVisible="{Binding HighlightedExampleDanish.IsFullTextOnly}"/>
                        <!-- Separator -->
                        <Rectangle
                            IsVisible="{Binding HasCurrentExampleEnglish}"
                            Height="1"
                            HorizontalAlignment="Center"
                            Width="200"
                            Margin="0,6,0,6"
                            Fill="#66888888" />
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            IsVisible="{Binding HasCurrentExampleEnglish}">
                            <Run
                                Text="{Binding HighlightedExampleEnglish.BeforeWord}"
                                FontSize="16" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.HighlightedWord}"
                                TextDecorations="Underline"
                                FontWeight="SemiBold"
                                FontSize="16" />
                            <Run
                                Text="{Binding HighlightedExampleEnglish.AfterWord}"
                                FontSize="16" />
                        </TextBlock>
                        <!-- Fallback: Show full text if highlighting failed -->
                        <TextBlock
                            FontSize="14"
                            TextWrapping="Wrap"
                            Foreground="#FFCBD5E1"
                            Text="{Binding HighlightedExampleEnglish.FullText}"
                            IsVisible="{Binding HighlightedExampleEnglish.IsFullTextOnly}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="8"
                IsVisible="{Binding IsAddRecordPage}">
                <TextBlock
                    Text="Add flashcard"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White" />

                <TextBox
                    Text="{Binding NewDanish}"
                    Watermark="Danish"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="60"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Text="{Binding NewEnglish}"
                    Watermark="English"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="60"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Text="{Binding NewType}"
                    Watermark="Type (optional)" />

                <TextBox
                    Text="{Binding NewConjugation}"
                    Watermark="Conjugation (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewExampleDanish}"
                    Watermark="Example Danish (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewExampleEnglish}"
                    Watermark="Example English (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBox
                    Text="{Binding NewContextualTip}"
                    Watermark="Contextual tip (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50" />

                <TextBlock
                    Text="{Binding ValidationMessage}"
                    IsVisible="{Binding HasValidationMessage}"
                    TextWrapping="Wrap"
                    Foreground="#FFFCA5A5"
                    FontSize="12" />

                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <Button
                        Content="Cancel"
                        Command="{Binding CancelAddRecordCommand}" />
                    <Button
                        Content="Save"
                        Command="{Binding SaveNewRecordCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- Quiz Page (Empty) -->
            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                Spacing="10"
                IsVisible="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1}">
                <TextBlock
                    Text="Quiz Page"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Writing Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="*,*">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </Grid.IsVisible>
                <!-- Writing Section 1: Danish Writing -->
                <Border
                    Grid.Row="0"
                    Margin="0,6,0,5"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock
                            Grid.Row="0"
                            Text="{Binding CurrentDanishWritingTitle}"
                            FontSize="12"
                            Foreground="#FFFBBF24"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4" />
                        <ScrollViewer
                            x:Name="DanishWritingScroller"
                            Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                            <TextBlock
                                x:Name="DanishWritingTextBlock"
                                FontSize="14"
                                Foreground="#FFCBD5E1"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Writing Section 2: English Writing -->
                <Border
                    Grid.Row="1"
                    Margin="0,5,0,0"
                    Padding="12"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock
                            Grid.Row="0"
                            Text="{Binding CurrentEnglishWritingTitle}"
                            FontSize="12"
                            Foreground="#FFFBBF24"
                            FontWeight="SemiBold"
                            Margin="0,0,0,4" />
                        <ScrollViewer
                            x:Name="EnglishWritingScroller"
                            Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                            <TextBlock
                                Text="{Binding CurrentEnglishWriting}"
                                FontSize="14"
                                Foreground="#FFCBD5E1"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Writing Page Bottom Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="◀"
                    Command="{Binding PreviousWritingCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding NextWritingCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Writing Page Edit/Add Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="2" />
                        <Binding Path="IsWritingPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    Classes="icon-btn"
                    CornerRadius="16"
                    Command="{Binding ShowEditWritingCommand}">
                    <Path
                        Width="15" Height="15"
                        Fill="#FFFBBF24"
                        Stretch="Uniform"
                        Data="M12,2 L14,4 L5,13 L2,14 L3,11 Z M13,3 L15,5" />
                </Button>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="18"
                    FontWeight="Bold"
                    Content="+"
                    Command="{Binding ShowAddWritingCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Add Writing Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="Auto,Auto,*,Auto,*,Auto,Auto"
                IsVisible="{Binding IsAddWritingPage}">
                <TextBlock
                    Grid.Row="0"
                    Text="Add writing exercise"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Margin="0,0,0,8" />

                <TextBox
                    Grid.Row="1"
                    Text="{Binding NewWritingDanishTitle}"
                    Watermark="Danish title (optional)"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Grid.Row="2"
                    Text="{Binding NewWritingDanish}"
                    Watermark="Danish text"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Margin="0,0,0,8"
                    VerticalAlignment="Stretch" />

                <TextBox
                    Grid.Row="3"
                    Text="{Binding NewWritingEnglishTitle}"
                    Watermark="English title (optional)"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Grid.Row="4"
                    Text="{Binding NewWritingEnglish}"
                    Watermark="English text"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Margin="0,0,0,8"
                    VerticalAlignment="Stretch" />

                <TextBlock
                    Grid.Row="5"
                    Text="{Binding ValidationMessage}"
                    IsVisible="{Binding HasValidationMessage}"
                    TextWrapping="Wrap"
                    Foreground="#FFFCA5A5"
                    FontSize="12" />

                <StackPanel
                    Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <Button
                        Content="Cancel"
                        Command="{Binding CancelAddWritingCommand}" />
                    <Button
                        Content="Save"
                        Command="{Binding SaveNewWritingCommand}" />
                 </StackPanel>
            </Grid>

            <!-- MBSP Quiz Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="*,Auto">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </Grid.IsVisible>

            <StackPanel
                Grid.Row="0"
                Spacing="10"
                VerticalAlignment="Top">

                <!-- Question -->
                <Border
                    Padding="14"
                    CornerRadius="12"
                    Background="#332E3A4F"
                    BorderBrush="#334BA3C7"
                    BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="{Binding CurrentMbspQuestionText}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="#FFE2E8F0"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            TextAlignment="Center" />
                        <TextBlock
                            Text="{Binding CurrentMbspQuestionEnglish}"
                            FontSize="13"
                            FontStyle="Italic"
                            Foreground="#FF94A3B8"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            TextAlignment="Center">
                            <TextBlock.IsVisible>
                                <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                                    <Binding Path="HasCurrentMbspQuestionEnglish" />
                                    <Binding Path="MbspShowEnglish" />
                                </MultiBinding>
                            </TextBlock.IsVisible>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Choice A -->
                <Button
                    Classes.choice-correct="{Binding MbspChoiceAResult, Converter={StaticResource EqualityConverter}, ConverterParameter=correct}"
                    Classes.choice-wrong="{Binding MbspChoiceAResult, Converter={StaticResource EqualityConverter}, ConverterParameter=wrong}"
                    Classes.choice-highlight="{Binding MbspChoiceAResult, Converter={StaticResource EqualityConverter}, ConverterParameter=highlight}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="12,10"
                    CornerRadius="10"
                    Command="{Binding SelectMbspChoiceCommand}"
                    CommandParameter="A"
                    IsEnabled="{Binding MbspSelectedChoice, Converter={x:Static ObjectConverters.IsNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border
                            Width="24" Height="24"
                            CornerRadius="12"
                            Background="#443B82F6"
                            BorderBrush="#664BA3C7"
                            BorderThickness="1">
                            <TextBlock Text="A" FontSize="12" FontWeight="Bold" Foreground="#FFE2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentMbspChoiceA}" FontSize="14" Foreground="#FFE2E8F0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CurrentMbspChoiceAEnglish}" FontSize="12" FontStyle="Italic" Foreground="#FF94A3B8" TextWrapping="Wrap">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                                        <Binding Path="HasCurrentMbspChoiceAEnglish" />
                                        <Binding Path="MbspShowEnglish" />
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Choice B -->
                <Button
                    Classes.choice-correct="{Binding MbspChoiceBResult, Converter={StaticResource EqualityConverter}, ConverterParameter=correct}"
                    Classes.choice-wrong="{Binding MbspChoiceBResult, Converter={StaticResource EqualityConverter}, ConverterParameter=wrong}"
                    Classes.choice-highlight="{Binding MbspChoiceBResult, Converter={StaticResource EqualityConverter}, ConverterParameter=highlight}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="12,10"
                    CornerRadius="10"
                    Command="{Binding SelectMbspChoiceCommand}"
                    CommandParameter="B"
                    IsEnabled="{Binding MbspSelectedChoice, Converter={x:Static ObjectConverters.IsNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border
                            Width="24" Height="24"
                            CornerRadius="12"
                            Background="#443B82F6"
                            BorderBrush="#664BA3C7"
                            BorderThickness="1">
                            <TextBlock Text="B" FontSize="12" FontWeight="Bold" Foreground="#FFE2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentMbspChoiceB}" FontSize="14" Foreground="#FFE2E8F0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CurrentMbspChoiceBEnglish}" FontSize="12" FontStyle="Italic" Foreground="#FF94A3B8" TextWrapping="Wrap">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                                        <Binding Path="HasCurrentMbspChoiceBEnglish" />
                                        <Binding Path="MbspShowEnglish" />
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Choice C (only shown when present) -->
                <Button
                    Classes.choice-correct="{Binding MbspChoiceCResult, Converter={StaticResource EqualityConverter}, ConverterParameter=correct}"
                    Classes.choice-wrong="{Binding MbspChoiceCResult, Converter={StaticResource EqualityConverter}, ConverterParameter=wrong}"
                    Classes.choice-highlight="{Binding MbspChoiceCResult, Converter={StaticResource EqualityConverter}, ConverterParameter=highlight}"
                    IsVisible="{Binding CurrentMbspHasChoiceC}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="12,10"
                    CornerRadius="10"
                    Command="{Binding SelectMbspChoiceCommand}"
                    CommandParameter="C"
                    IsEnabled="{Binding MbspSelectedChoice, Converter={x:Static ObjectConverters.IsNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border
                            Width="24" Height="24"
                            CornerRadius="12"
                            Background="#443B82F6"
                            BorderBrush="#664BA3C7"
                            BorderThickness="1">
                            <TextBlock Text="C" FontSize="12" FontWeight="Bold" Foreground="#FFE2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentMbspChoiceC}" FontSize="14" Foreground="#FFE2E8F0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CurrentMbspChoiceCEnglish}" FontSize="12" FontStyle="Italic" Foreground="#FF94A3B8" TextWrapping="Wrap">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                                        <Binding Path="HasCurrentMbspChoiceCEnglish" />
                                        <Binding Path="MbspShowEnglish" />
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Feedback -->
                <TextBlock
                    Text="{Binding MbspAnswerFeedback}"
                    IsVisible="{Binding MbspHasFeedback}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Foreground="#FF86EFAC" />

            </StackPanel>

                <!-- Score + result (bottom) -->
                <StackPanel
                    Grid.Row="1"
                    Spacing="2"
                    Margin="0,8,0,10">
                    <!-- PASS -->
                    <TextBlock
                        Text="PASS"
                        IsVisible="{Binding MbspResultIsPass}"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="#FF22C55F"
                        HorizontalAlignment="Center" />
                    <!-- FAIL -->
                    <TextBlock
                        Text="FAIL"
                        IsVisible="{Binding MbspResultIsFail}"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="#FFEF4444"
                        HorizontalAlignment="Center" />
                    <!-- Correct | Wrong   ◀ left        right ▶   Question# | Total -->
                    <Grid ColumnDefinitions="*,*">
                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding MbspCorrectWrongText}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="#FF94A3B8"
                            HorizontalAlignment="Left" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding MbspQuestionProgressText}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="#FF94A3B8"
                            HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- MBSP Add/Edit Page -->
            <Grid
                Grid.Row="4"
                Margin="0,12,0,0"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsAddMbspPage" />
                    </MultiBinding>
                </Grid.IsVisible>

                <TextBlock
                    Grid.Row="0"
                    Text="Add / Edit Question"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Margin="0,0,0,8" />

                <TextBox
                    Grid.Row="1"
                    Text="{Binding NewMbspQuestion}"
                    Watermark="Question (Danish)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="60"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Stretch" />

                <TextBox
                    Grid.Row="2"
                    Text="{Binding NewMbspQuestionEnglish}"
                    Watermark="Question English (optional)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="50"
                    Margin="0,0,0,6"
                    HorizontalAlignment="Stretch" />

                <!-- Choice A with radio button -->
                <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,0,0,2">
                    <RadioButton
                        Grid.Column="0"
                        GroupName="MbspCorrect"
                        IsChecked="{Binding NewMbspCorrectChoiceIsA, Mode=TwoWay}"
                        ToolTip.Tip="Mark as correct answer"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBox Text="{Binding NewMbspChoiceA}" Watermark="Choice A" HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding NewMbspChoiceAEnglish}" Watermark="Choice A English (optional)" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>

                <!-- Choice B with radio button -->
                <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,4,0,2">
                    <RadioButton
                        Grid.Column="0"
                        GroupName="MbspCorrect"
                        IsChecked="{Binding NewMbspCorrectChoiceIsB, Mode=TwoWay}"
                        ToolTip.Tip="Mark as correct answer"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBox Text="{Binding NewMbspChoiceB}" Watermark="Choice B" HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding NewMbspChoiceBEnglish}" Watermark="Choice B English (optional)" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>

                <!-- Choice C with radio button (optional) -->
                <Grid Grid.Row="5" ColumnDefinitions="Auto,*" Margin="0,4,0,6">
                    <RadioButton
                        Grid.Column="0"
                        GroupName="MbspCorrect"
                        IsChecked="{Binding NewMbspCorrectChoiceIsC, Mode=TwoWay}"
                        ToolTip.Tip="Mark as correct answer"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBox Text="{Binding NewMbspChoiceC}" Watermark="Choice C (optional)" HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding NewMbspChoiceCEnglish}" Watermark="Choice C English (optional)" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>

                <!-- Period (optional) -->
                <TextBox
                    Grid.Row="6"
                    Text="{Binding NewMbspPeriod}"
                    Watermark="Period (optional, e.g. 2024)"
                    Margin="0,0,0,6"
                    HorizontalAlignment="Stretch" />

                <StackPanel
                    Grid.Row="7"
                    Spacing="4">
                    <TextBlock
                        Text="{Binding ValidationMessage}"
                        IsVisible="{Binding HasValidationMessage}"
                        TextWrapping="Wrap"
                        Foreground="#FFFCA5A5"
                        FontSize="12" />
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                        <Button Content="Cancel" Command="{Binding CancelMbspCommand}" />
                        <Button Content="Save" Command="{Binding SaveMbspCommand}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- MBSP Bottom Nav Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32" Height="32"
                    CornerRadius="16"
                    FontSize="14" FontWeight="SemiBold"
                    Content="◀"
                    Command="{Binding PreviousMbspCommand}"
                    IsEnabled="{Binding CanGoToPreviousMbsp}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" />
                <Button
                    Width="32" Height="32"
                    CornerRadius="16"
                    FontSize="14" FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding NextMbspCommand}"
                    IsEnabled="{Binding CanGoToNextMbsp}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" />
            </StackPanel>

            <!-- MBSP Edit/Add Buttons -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,0,0"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32" Height="32"
                    Classes="icon-btn"
                    CornerRadius="16"
                    Command="{Binding ShowEditMbspCommand}">
                    <Path
                        Width="15" Height="15"
                        Fill="#FFFBBF24"
                        Stretch="Uniform"
                        Data="M12,2 L14,4 L5,13 L2,14 L3,11 Z M13,3 L15,5" />
                </Button>
                <Button
                    Width="32" Height="32"
                    CornerRadius="16"
                    FontSize="18" FontWeight="Bold"
                    Content="+"
                    Command="{Binding ShowAddMbspCommand}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" />
            </StackPanel>

            <!-- MBSP Eng Toggle Switch (bottom-left corner) -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Center">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="3" />
                        <Binding Path="IsMbspPage" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <views:EngToggle
                    IsChecked="{Binding MbspShowEnglish, Mode=TwoWay}"
                    ToolTip.Tip="Show / hide English translation" />
            </StackPanel>

            <!-- Contextual Tip -->
            <Border
                Grid.Row="5"
                Margin="0,8,0,0"
                Padding="8,6"
                CornerRadius="8"
                Background="#22F59E0B">
                <Border.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="HasCurrentContextualTip" />
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Border.IsVisible>
                <Grid
                    ColumnDefinitions="Auto,*">
                    <TextBlock
                        Grid.Column="0"
                        Text="💡"
                        FontSize="12"
                        VerticalAlignment="Top"
                        Margin="0,0,6,0" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding CurrentContextualTip}"
                        FontSize="14"
                        TextWrapping="Wrap"
                        Foreground="#FFFBBF24" />
                </Grid>
            </Border>

            <!-- Add Flashcard -->
            <Button
                Grid.Row="6"
                Width="32"
                Height="32"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                CornerRadius="16"
                FontSize="18"
                FontWeight="Bold"
                Content="+"
                Command="{Binding ShowAddRecordCommand}"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
                <Button.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Edit Flashcard -->
            <Button
                Grid.Row="6"
                Width="32"
                Height="32"
                Margin="0,0,44,0"
                Classes="icon-btn"
                CornerRadius="16"
                Command="{Binding ShowEditRecordCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom">
                <Path
                    Width="15" Height="15"
                    Fill="#FFFBBF24"
                    Stretch="Uniform"
                    Data="M12,2 L14,4 L5,13 L2,14 L3,11 Z M13,3 L15,5" />
                <Button.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="HasFlashcards" />
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </Button.IsVisible>
            </Button>

            <!-- Previous/Next Flashcard -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="◀"
                    Command="{Binding PreviousCardCommand}"
                    IsEnabled="{Binding CanNavigateFlashcards}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding NextCardCommand}"
                    IsEnabled="{Binding CanNavigateFlashcards}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Auto / Pause Rotate Flashcard -->
            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                Spacing="8">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource MultiBooleanAndConverter}">
                        <Binding Path="IsFlashcardPage" />
                        <Binding Path="SelectedTabIndex" Converter="{StaticResource EqualityConverter}" ConverterParameter="0" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Content="▶"
                    Command="{Binding PlayCommand}"
                    IsEnabled="{Binding IsRotationPaused}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
                <Button
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Content="⏸"
                    Command="{Binding PauseCommand}"
                    IsEnabled="{Binding IsRotationPlaying}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>

</Window>